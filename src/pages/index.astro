---
const title = "Qamareth SRD";
---
<html lang="pt-BR">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <style>
      body { margin:0; font-family: system-ui, sans-serif; background:#0b0c10; color:#e9e2d0; }
      main { max-width: 900px; margin: 0 auto; padding: 32px 18px; }
      a { color:#c9a44b; text-decoration:none; }
      a:hover { text-decoration: underline; }
      .card { background:#0f1117; border:1px solid rgba(233,226,208,.15); border-radius:16px; padding:18px; }
    </style>
  </head>
  <body>
    <main>
      <div class="card">
        <h1>Qamareth SRD</h1>
        <p>SRD do sistema: magia musical (modos/ritmo), combate cinematográfico e magi-tech arcano.</p>
        <p><a href="/srd/introducao.md">Começar →</a></p>
      </div>
    </main>
  </body>
</html>
