---
import Layout from '../../layouts/Layout.astro';
import Sigil from '../../components/Sigil.astro';

const categories = [
  {
    glyph: '♩',
    title: 'Sistema de Magia',
    href: '/grimorios/sistema-de-magia',
    desc: 'Referência visual: RS por faixa, tabela de Corais, cards de Motifs Base/Ornamentação/Mestres e exemplos de Motif de Origem.',
  },
  {
    glyph: '⚜',
    title: 'Motivos de Origem',
    href: '/grimorios/motivos-de-origem',
    desc: 'A alma musical de cada herói — como criar, nomear e usar seu Motivo de Origem.',
  },
  {
    glyph: '✦',
    title: 'Armas Ressonantes',
    href: '/grimorios/armas-ressonantes',
    desc: 'Stormscream, Raízel\'Thandor, Aethraferro, Lameira e outras armas com personalidade e evolução.',
  },
  {
    glyph: '♬',
    title: 'Partituras',
    href: '/grimorios/partituras',
    desc: 'Feitiços em formato de partitura — Motifs aplicados a magias base com sabor e crunch.',
  },
  {
    glyph: '◈',
    title: 'Rituais',
    href: '/grimorios/rituais',
    desc: 'Os grandes ritos do Harmonium adaptados para uso mecânico em jogo.',
  },
  {
    glyph: '☦',
    title: 'Liturgias Completas',
    href: '/grimorios/liturgias',
    desc: 'As cinco liturgias da Aurora de Prata — do texto completo aos efeitos mecânicos. Para narrar, participar e ser transformado.',
  },
  {
    glyph: '⚔',
    title: 'Armas Sencientes',
    href: '/grimorios/armas-sencientes',
    desc: 'Framework completo para criar armas com consciência, personalidade e poder que evolui. Inclui as quatro armas canônicas.',
  },
];
---

<Layout title="Grimórios · Qamareth" section="grimorios" description="Conteúdo de uso direto em jogo — partituras, armas, motivos e rituais.">

  <section class="qa-hero">
    <div class="qa-hero-inner">
      <div class="qa-hero-sigil">
        <Sigil size={80} animate={false} />
      </div>
      <div class="qa-hero-text">
        <p class="qa-hero-eyebrow">Grimórios</p>
        <h1 class="qa-hero-title">Conteúdo de Jogo</h1>
        <p class="qa-hero-desc">
          Partituras, rituais, motivos de combate e armas ressonantes — tudo que
          entra direto na mesa. Conteúdo oficial compatível com o sistema Qamareth.
        </p>
      </div>
    </div>
  </section>

  <section class="qa-grid-section">
    <div class="qa-grid-wrap">
      <div class="qa-grid">
        {categories.map((cat, i) => (
          cat.soon
            ? (
              <div class="qa-card qa-card--soon" style={`animation-delay: ${0.1 + i * 0.07}s`}>
                <span class="qa-card-glyph">{cat.glyph}</span>
                <div class="qa-card-body">
                  <h2 class="qa-card-title">{cat.title}</h2>
                  <p class="qa-card-desc">{cat.desc}</p>
                </div>
                <span class="qa-card-badge">Em breve</span>
              </div>
            )
            : (
              <a href={cat.href} class="qa-card" style={`animation-delay: ${0.1 + i * 0.07}s`}>
                <span class="qa-card-glyph">{cat.glyph}</span>
                <div class="qa-card-body">
                  <h2 class="qa-card-title">{cat.title}</h2>
                  <p class="qa-card-desc">{cat.desc}</p>
                </div>
                <span class="qa-card-arrow">→</span>
              </a>
            )
        ))}
      </div>
    </div>
  </section>

</Layout>
