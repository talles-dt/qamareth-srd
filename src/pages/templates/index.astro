---
import Layout from '../../layouts/Layout.astro';
import Sigil from '../../components/Sigil.astro';

const items = [
  { glyph: '♩', title: 'Partitura',  href: '/templates/partitura', desc: 'Estrutura base para criar e documentar partituras no sistema Qamareth.' },
  { glyph: '☠', title: 'Inimigo',    href: '/templates/inimigo',   desc: 'Ficha de referência para criar arquétipos e inimigos para a mesa.' },
  { glyph: '◎', title: 'Escola',     href: '/templates/escola',    desc: 'Como estruturar uma escola ou tradição musical dentro do mundo.' },
  { glyph: '◈', title: 'Grimório',   href: '/templates/grimorio',  desc: 'Template completo para compilar um grimório de tradição arcana.' },
];
---

<Layout title="Templates · Qamareth" section="templates" description="Templates de referência para criação de conteúdo compatível com o sistema Qamareth.">

  <section class="section-hero">
    <div class="section-hero-inner">
      <div class="section-hero-sigil">
        <Sigil size={80} animate={false} />
      </div>
      <div class="section-hero-text">
        <p class="section-eyebrow font-cinzel">Templates</p>
        <h1 class="section-title font-cinzel-d">Referência de Criação</h1>
        <p class="section-desc font-garamond">
          Estruturas padronizadas para criar partituras, inimigos, escolas e grimórios
          compatíveis com o sistema Qamareth. Use como ponto de partida.
        </p>
      </div>
    </div>
  </section>

  <section class="lore-grid-section">
    <div class="lore-grid-wrap">
      <div class="lore-grid">
        {items.map((item, i) => (
          <a href={item.href} class="lore-card" style={`animation-delay: ${0.1 + i * 0.07}s`}>
            <span class="lore-card-glyph">{item.glyph}</span>
            <div class="lore-card-body">
              <h2 class="lore-card-title font-cinzel">{item.title}</h2>
              <p class="lore-card-desc font-garamond">{item.desc}</p>
            </div>
            <span class="lore-card-arrow">→</span>
          </a>
        ))}
      </div>
    </div>
  </section>

</Layout>

<style>
  .section-hero { border-bottom: 1px solid var(--border); padding: 52px 24px 48px; background: linear-gradient(to bottom, rgba(201,164,75,0.03), transparent); }
  .section-hero-inner { max-width: 880px; margin: 0 auto; display: flex; gap: 32px; align-items: center; }
  .section-hero-sigil { flex-shrink: 0; opacity: 0.65; animation: qa-fade-in 0.8s var(--ease-out) both; }
  .section-eyebrow { font-size: 0.62rem; letter-spacing: 0.3em; text-transform: uppercase; color: var(--gold-dim); margin-bottom: 8px; }
  .section-title { font-size: clamp(1.6rem, 4vw, 2.6rem); font-weight: 400; color: var(--gold-bright); margin-bottom: 14px; animation: qa-rise 0.8s var(--ease-out) 0.1s both; }
  .section-desc { font-size: 1.05rem; font-style: italic; color: var(--text-muted); line-height: 1.8; max-width: 620px; animation: qa-drift 0.8s var(--ease-out) 0.2s both; }
  .lore-grid-section { padding: 48px 24px 80px; }
  .lore-grid-wrap { max-width: 880px; margin: 0 auto; }
  .lore-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 14px; }
  .lore-card { position: relative; display: grid; grid-template-columns: auto 1fr auto; align-items: start; gap: 14px; padding: 20px 18px; background: var(--surface); border: 1px solid var(--border); border-radius: var(--radius-lg); text-decoration: none; transition: transform 0.2s var(--ease-out), border-color 0.2s, background 0.2s, box-shadow 0.3s; animation: qa-drift 0.6s var(--ease-out) both; overflow: hidden; }
  .lore-card::before { content: ''; position: absolute; inset: 0; background: linear-gradient(135deg, var(--gold-ghost), transparent 60%); opacity: 0; transition: opacity 0.3s; }
  .lore-card:hover { transform: translateY(-2px); border-color: var(--gold-hover); background: var(--surface-2); box-shadow: 0 10px 32px rgba(0,0,0,0.4); }
  .lore-card:hover::before { opacity: 1; }
  .lore-card-glyph { font-size: 1.5rem; color: var(--gold-dim); width: 32px; text-align: center; margin-top: 2px; transition: color 0.2s; position: relative; }
  .lore-card:hover .lore-card-glyph { color: var(--gold); }
  .lore-card-body { min-width: 0; position: relative; }
  .lore-card-title { font-size: 0.72rem; letter-spacing: 0.2em; text-transform: uppercase; color: var(--gold); margin-bottom: 7px; transition: color 0.2s; }
  .lore-card:hover .lore-card-title { color: var(--gold-bright); }
  .lore-card-desc { font-size: 0.92rem; line-height: 1.6; color: var(--text-muted); margin: 0; transition: color 0.2s; }
  .lore-card:hover .lore-card-desc { color: var(--text); }
  .lore-card-arrow { color: var(--text-faint); font-size: 1rem; margin-top: 3px; flex-shrink: 0; transition: transform 0.2s var(--ease-out), color 0.2s; position: relative; }
  .lore-card:hover .lore-card-arrow { transform: translateX(3px); color: var(--gold-dim); }
  @media (max-width: 700px) {
    .section-hero-inner { flex-direction: column; align-items: flex-start; gap: 20px; }
    .section-hero-sigil { display: none; }
    .lore-grid { grid-template-columns: 1fr; }
    .lore-card { grid-template-columns: auto 1fr; }
    .lore-card-arrow { display: none; }
  }
</style>
