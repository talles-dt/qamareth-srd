<!DOCTYPE html>---
const chapters = [
 ["00-introducao", "Introdução"],
  ["01-criacao-personagem", "Criação de Personagem"],
  ["02-atributos", "Atributos e Disciplinas"],
  ["03-testes", "Resolução de Testes"],
  ["04-magia-musical", "Magia Musical"],
  ["05-tensao-harmonica", "Tensão Harmônica"],
  ["06-combate", "Combate"],
  ["07-ferimentos", "Ferimentos"],
  ["08-magi-tech", "Magi-Tech"],
  ["09-honra-status-influencia", "Honra, Status e Influência"],
  ["10-paixoes", "Paixões"],
  ["11-bestiario-arquetipos", "Arquétipos de Inimigos"],
  ["12-temas-e-conflitos", "Temas e Conflitos"],
  ["13-faccoes", "Facções e Poder"],
  ["14-economia", "Economia e Recursos"],
  ["15-bastions", "Bastions"],
  ["16-influencia-politica", "Influência e Política"],
  ["17-magia-coletiva", "Magia Coletiva e Corais"],
  ["18-ritmo-tempo-combate", "Ritmo e Tempo de Combate"],
  ["19-motivos-combate", "Motivos de Combate"],
  ["20-escolas-e-tradicoes", "Escolas e Tradições"],
  ["90-template-partitura", "Modelo de Partitura para efeitos mágicos"],
  ["91-template-inimigo", "Modelo de criação de inimigos em geral"],
  ["92-template-escola", "Modelo para criar nova escola para personagens"],
  ["99-licenca", "Licença (CC BY 4.0)"]
];
---
<html lang="pt-BR">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Qamareth SRD • Índice</title>
    <style>
      body{margin:0;font-family:system-ui,sans-serif;background:#0b0c10;color:#e9e2d0}
      main{max-width:980px;margin:0 auto;padding:32px 18px}
      a{color:#c9a44b;text-decoration:none}
      a:hover{text-decoration:underline}
      .card{background:#0f1117;border:1px solid rgba(233,226,208,.15);border-radius:16px;padding:18px}
      ul{line-height:1.85}
      .muted{color:rgba(233,226,208,.7)}
    </style>
  </head>
  <body>
    <main>
      <div class="card">
        <h1>Qamareth SRD</h1>
        <p class="muted">v0.2 — núcleo consolidado (em expansão).</p>
        <h2>Capítulos</h2>
        <ul>
          {chapters.map(([slug, title]) => (
            <li><a href={`/srd/${slug}`}>{title}</a></li>
          ))}
        </ul>
        <p><a href="/">← Voltar</a></p>
      </div>
    </main>
  </body>
</html>
