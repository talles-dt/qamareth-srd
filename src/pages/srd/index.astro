---
import Layout from '../../layouts/Layout.astro';
import Sigil from '../../components/Sigil.astro';

const blocks = [
  {
    label: 'Fundamentos',
    chapters: [
      { num: '00', title: 'Introdução',              href: '/srd/00-introducao',          desc: 'Princípios de design, o que este SRD cobre e como usar.' },
      { num: '01', title: 'Criação de Personagem',   href: '/srd/01-criacao-personagem',  desc: 'As 20 perguntas — origem, escola, RS inicial, paixão dominante.' },
      { num: '02', title: 'Atributos e Disciplinas', href: '/srd/02-atributos',            desc: 'Os 5 pilares (3×5) e a escala de dados por treino.' },
      { num: '03', title: 'Testes e Rolagens',       href: '/srd/03-testes',               desc: 'Pool, sucesso em 7+, explosão e margem de sucessos.' },
    ],
  },
  {
    label: 'Magia',
    chapters: [
      { num: '04', title: 'Magia Musical',     href: '/srd/04-magia-musical',     desc: 'Modos, Ritmos, Intervalos, Partituras e RS mínimo por complexidade.' },
      { num: '05', title: 'Tensão Harmônica',  href: '/srd/05-tensao-harmonica',  desc: 'Peso Harmônico, limite de tensão e eventos de ruptura (níveis 1–4).' },
      { num: '17', title: 'Magia Coletiva',    href: '/srd/17-magia-coletiva',    desc: 'Corais, amplificação por multidões e rituais coletivos.' },
    ],
  },
  {
    label: 'Combate',
    chapters: [
      { num: '06', title: 'Combate',            href: '/srd/06-combate',             desc: 'Tempo da cena, ações, iniciativa e posturas (Forte, Legato, Staccato, Rubato).' },
      { num: '07', title: 'Ferimentos',         href: '/srd/07-ferimentos',           desc: 'Trilha de estados, penalidades e recuperação. Sem HP.' },
      { num: '18', title: 'Ritmo e Tempo',      href: '/srd/18-ritmo-tempo-combate',  desc: '4/4 marcial, 3/4 duelo, 5/4 irregular, 7/8 frenesi.' },
      { num: '19', title: 'Motivos de Combate', href: '/srd/19-motivos-combate',      desc: 'Padrões recorrentes de ação — condição, execução, efeito.' },
    ],
  },
  {
    label: 'Personagem',
    chapters: [
      { num: '08', title: 'Magi-Tech',                 href: '/srd/08-magi-tech',                 desc: 'Tecnologia arcano-renascentista — dispositivos, infraestrutura, máquinas.' },
      { num: '09', title: 'Honra, Status, Influência', href: '/srd/09-honra-status-influencia',   desc: 'Coerência moral, hierarquia e capital político em Qamareth.' },
      { num: '10', title: 'Paixões',                   href: '/srd/10-paixoes',                   desc: 'As 8 paixões, escala 0–5, aumento, resistência e redenção.' },
      { num: '20', title: 'Escolas e Tradições',       href: '/srd/20-escolas-e-tradicoes',       desc: 'Escolas de formação e tradições musicais do mundo.' },
    ],
  },
  {
    label: 'Mundo e Narrativa',
    chapters: [
      { num: '11', title: 'Arquétipos de Inimigos', href: '/srd/11-bestiario-arquetipos', desc: '8 arquétipos (Brutamontes a Entidade) e template de criatura.' },
      { num: '12', title: 'Temas e Conflitos',      href: '/srd/12-temas-e-conflitos',    desc: 'Os 5 eixos de tensão estrutural do cenário.' },
      { num: '13', title: 'Facções',                href: '/srd/13-faccoes',              desc: 'Estrutura, recursos, ideologia e criação de facções.' },
      { num: '14', title: 'Economia',               href: '/srd/14-economia',             desc: 'Escala de riqueza, testes econômicos e projetos.' },
      { num: '15', title: 'Bastions',               href: '/srd/15-bastions',             desc: 'Centros de poder — níveis I a V, melhorias e eventos.' },
      { num: '16', title: 'Influência Política',    href: '/srd/16-influencia-politica',  desc: 'IP, favores, intriga, dívidas e relações com facções.' },
    ],
  },
];
---
<Layout title="SRD · Qamareth" section="srd" description="O Sistema de Referência de Design — as regras centrais de Qamareth.">

  <section class="section-hero">
    <div class="hero-inner">
      <div class="hero-sigil"><Sigil size={80} animate={false} /></div>
      <div class="hero-text">
        <p class="eyebrow font-cinzel">SRD</p>
        <h1 class="hero-title font-cinzel-d">Sistema de Referência</h1>
        <p class="hero-desc font-garamond">
          As regras que governam Qamareth — 21 capítulos, do básico à política
          continental. Um sistema onde a música é a mecânica fundamental da magia,
          da fé e do poder.
        </p>
        <a href="/srd/00-introducao" class="hero-cta font-cinzel">
          Começar pela Introdução →
        </a>
      </div>
    </div>
  </section>

  <section class="chapters-section">
    <div class="chapters-wrap">
      {blocks.map(block => (
        <div class="block">
          <h2 class="block-title font-cinzel">{block.label}</h2>
          <div class="block-grid">
            {block.chapters.map(ch => (
              <a href={ch.href} class="chapter-card">
                <span class="ch-num font-cinzel">{ch.num}</span>
                <div class="ch-body">
                  <h3 class="ch-title font-cinzel">{ch.title}</h3>
                  <p class="ch-desc font-garamond">{ch.desc}</p>
                </div>
                <span class="ch-arrow" aria-hidden="true">→</span>
              </a>
            ))}
          </div>
        </div>
      ))}
    </div>
  </section>

</Layout>

<style>
  .section-hero { border-bottom:1px solid var(--border); padding:52px 24px 48px; background:linear-gradient(to bottom,rgba(201,164,75,.03),transparent); }
  .hero-inner { max-width:900px; margin:0 auto; display:flex; gap:32px; align-items:center; }
  .hero-sigil { flex-shrink:0; opacity:.65; animation:qa-fade-in .8s var(--ease-out) both; }
  .eyebrow { font-size:.62rem; letter-spacing:.3em; text-transform:uppercase; color:var(--gold-dim); margin-bottom:8px; }
  .hero-title { font-size:clamp(1.6rem,4vw,2.6rem); font-weight:400; color:var(--gold-bright); margin-bottom:14px; animation:qa-rise .8s var(--ease-out) .1s both; }
  .hero-desc { font-size:1.02rem; font-style:italic; color:var(--text-muted); line-height:1.8; max-width:560px; margin-bottom:20px; }
  .hero-cta { display:inline-flex; align-items:center; font-size:.68rem; letter-spacing:.18em; text-transform:uppercase; color:var(--gold); border:1px solid var(--gold-border); background:var(--gold-ghost); border-radius:var(--radius-sm); padding:8px 16px; text-decoration:none; transition:border-color .2s,background .2s,color .2s; }
  .hero-cta:hover { border-color:var(--gold-hover); background:rgba(201,164,75,.16); color:var(--gold-bright); }
  .chapters-section { padding:48px 24px 80px; }
  .chapters-wrap { max-width:900px; margin:0 auto; display:flex; flex-direction:column; gap:44px; }
  .block-title { font-size:.62rem; letter-spacing:.3em; text-transform:uppercase; color:var(--text-faint); margin-bottom:14px; padding-bottom:10px; border-bottom:1px solid var(--border-2); }
  .block-grid { display:flex; flex-direction:column; gap:6px; }
  .chapter-card { display:grid; grid-template-columns:30px 1fr auto; align-items:center; gap:14px; padding:14px 16px; background:var(--surface); border:1px solid var(--border); border-radius:var(--radius); text-decoration:none; transition:transform .15s var(--ease-out),border-color .2s,background .2s; }
  .chapter-card:hover { transform:translateX(3px); border-color:var(--gold-hover); background:var(--surface-2); }
  .ch-num { font-size:.62rem; letter-spacing:.1em; color:var(--text-faint); text-align:right; flex-shrink:0; transition:color .2s; }
  .chapter-card:hover .ch-num { color:var(--gold-dim); }
  .ch-body { display:flex; align-items:baseline; gap:12px; min-width:0; flex-wrap:wrap; }
  .ch-title { font-size:.75rem; letter-spacing:.12em; text-transform:uppercase; color:var(--gold); white-space:nowrap; transition:color .2s; }
  .chapter-card:hover .ch-title { color:var(--gold-bright); }
  .ch-desc { font-size:.9rem; color:var(--text-faint); margin:0; transition:color .2s; }
  .chapter-card:hover .ch-desc { color:var(--text-muted); }
  .ch-arrow { font-size:.9rem; color:var(--text-faint); flex-shrink:0; transition:transform .15s,color .2s; }
  .chapter-card:hover .ch-arrow { transform:translateX(2px); color:var(--gold-dim); }
  @media(max-width:700px) {
    .hero-inner { flex-direction:column; align-items:flex-start; gap:20px; }
    .hero-sigil { display:none; }
    .ch-desc { display:none; }
    .chapter-card { grid-template-columns:24px 1fr auto; }
  }
</style>
