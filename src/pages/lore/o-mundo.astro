import ContentLayout from '../../layouts/ContentLayout.astro';

const navItems = [
  {
    href: '/lore',
    label: 'Lore',
    sub: [
      { href: '/lore/o-mundo',     label: 'O Mundo' },
      { href: '/lore/o-imperio',   label: 'O Império' },
      { href: '/lore/o-harmonium', label: 'O Harmonium' },
      { href: '/lore/faccoes',     label: 'Facções' },
      { href: '/lore/regioes',     label: 'Regiões' },
      { href: '/lore/cosmologia',  label: 'Cosmologia' },
    ],
