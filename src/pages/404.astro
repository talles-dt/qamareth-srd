---
import Layout from '../layouts/Layout.astro';
import Sigil from '../components/Sigil.astro';
---

<Layout title="404 · Dissonância · Qamareth">

  <div class="error-shell">

    <div class="sigil-wrap">
      <Sigil size={160} animate={true} />
      <div class="dissonance-ring"></div>
    </div>

    <p class="error-code font-cinzel">Tensão Harmônica — Nível 4</p>
    <h1 class="error-title font-cinzel-deco">Ruptura no Tecido</h1>

    <p class="error-desc font-garamond">
      A nota que você buscou não existe nesta partitura.<br />
      O Véu de Ephira engoliu esta passagem — ou ela nunca foi escrita.
    </p>

    <div class="error-divider">✦</div>

    <nav class="error-nav font-cinzel">
      <a href="/" class="error-link">← Início</a>
      <a href="/lore" class="error-link">Lore</a>
      <a href="/srd" class="error-link">SRD</a>
      <a href="/grimorios" class="error-link">Grimórios</a>
    </nav>

  </div>

</Layout>

<style>
  .error-shell {
    min-height: 80vh;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding: 60px 24px;
    gap: 0;
  }

  /* Sigil + anel de dissonância */
  .sigil-wrap {
    position: relative;
    width: 160px;
    height: 160px;
    margin-bottom: 40px;
  }

  .dissonance-ring {
    position: absolute;
    inset: -20px;
    border-radius: 50%;
    border: 1px solid rgba(201, 164, 75, 0.18);
    animation: crack-pulse 3.5s ease-in-out infinite;
  }

  .dissonance-ring::before,
  .dissonance-ring::after {
    content: '';
    position: absolute;
    inset: 10px;
    border-radius: 50%;
    border: 1px solid rgba(201, 164, 75, 0.10);
    animation: crack-pulse 3.5s ease-in-out infinite reverse;
  }

  @keyframes crack-pulse {
    0%, 100% { opacity: 0.3; transform: scale(1); }
    50%       { opacity: 0.8; transform: scale(1.04); }
  }

  /* Código de erro */
  .error-code {
    font-size: 0.62rem;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: var(--gold-dim);
    margin: 0 0 12px;
    opacity: 0.7;
  }

  /* Título */
  .error-title {
    font-size: clamp(2rem, 6vw, 3.2rem);
    font-weight: 400;
    color: var(--gold-bright);
    margin: 0 0 20px;
    line-height: 1.15;
    text-shadow: 0 0 40px rgba(201, 164, 75, 0.25);
  }

  /* Descrição */
  .error-desc {
    font-size: 1.05rem;
    color: var(--text-muted);
    line-height: 1.8;
    max-width: 420px;
    margin: 0 auto 28px;
  }

  /* Divisor */
  .error-divider {
    color: var(--gold-dim);
    font-size: 0.75rem;
    letter-spacing: 0.4em;
    margin-bottom: 28px;
    opacity: 0.5;
  }

  /* Nav links */
  .error-nav {
    display: flex;
    gap: 8px 24px;
    flex-wrap: wrap;
    justify-content: center;
  }

  .error-link {
    font-size: 0.65rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--gold-dim);
    text-decoration: none;
    padding: 8px 16px;
    border: 1px solid var(--border);
    border-radius: var(--radius);
    background: var(--surface);
    transition: color 0.2s, border-color 0.2s, background 0.2s;
  }

  .error-link:hover {
    color: var(--gold);
    border-color: var(--gold-dim);
    background: var(--surface-2);
  }
</style>
