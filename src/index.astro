---
import Layout from '../../layouts/Layout.astro';
import Sigil from '../../components/Sigil.astro';

const sections = [
  {
    glyph:  '✦',
    title:  'SRD',
    href:   '/srd',
    desc:   'As regras centrais: criação de personagem, testes, magia musical, combate, bastions, política e progressão.',
    accent: 'card--srd',
  },
  {
    glyph:  '☽',
    title:  'Lore',
    href:   '/lore',
    desc:   'História, facções, regiões, cosmologia, religião, tecnologia e os grandes conflitos do mundo de Qamareth.',
    accent: 'card--lore',
  },
  {
    glyph:  '♬',
    title:  'Grimórios',
    href:   '/grimorios',
    desc:   'Partituras, rituais, motivos de combate, tradições musicais e conteúdos de uso direto em jogo.',
    accent: 'card--grim',
  },
  {
    glyph:  '⬡',
    title:  'Templates',
    href:   '/templates',
    desc:   'Modelos oficiais para criar partituras, inimigos, facções, escolas, bastions e outros conteúdos compatíveis.',
    accent: 'card--tmpl',
  },
];
---

<Layout
  title="Qamareth"
  description="Sistema de fantasia arcano-musical — onde harmonia, fé, intriga, tecnologia e poder territorial moldam o destino do mundo."
>

  <!-- ═══════════════════ HERO ═══════════════════ -->
  <section class="hero">

    <!-- Sigilo animado -->
    <div class="hero-sigil">
      <Sigil size={300} animate={true} />
    </div>

    <!-- Título -->
    <h1 class="hero-title font-cinzel-d">Qamareth</h1>

    <!-- Ornamento -->
    <div class="hero-ornament" aria-hidden="true">
      <span class="orn-line"></span>
      <span class="orn-gem">✦</span>
      <span class="orn-line"></span>
    </div>

    <!-- Tagline -->
    <p class="hero-tagline font-garamond">
      Um mundo onde a música não é arte — é <em>feitiçaria</em>.<br/>
      Onde os acordes governam exércitos e o silêncio pode matar.
    </p>

    <!-- Subtítulo / Sistema -->
    <p class="hero-system font-cinzel">
      Sistema Proprietário · Licença CC BY 4.0
    </p>

  </section>

  <!-- ═══════════════════ SEÇÕES ═══════════════════ -->
  <section class="cards-section">
    <div class="cards-wrap">

      <!-- Linha ornamental acima -->
      <div class="section-divider" aria-hidden="true">
        <span class="div-line"></span>
        <span class="div-center font-cinzel">Codex</span>
        <span class="div-line"></span>
      </div>

      <!-- Grid de cards -->
      <div class="cards-grid">
        {sections.map((s, i) => (
          <a
            href={s.href}
            class:list={['card', s.accent]}
            style={`animation-delay: ${0.55 + i * 0.1}s`}
          >
            <span class="card-glyph" aria-hidden="true">{s.glyph}</span>
            <div class="card-body">
              <h2 class="card-title font-cinzel">{s.title}</h2>
              <p class="card-desc font-garamond">{s.desc}</p>
            </div>
            <span class="card-arrow" aria-hidden="true">→</span>
          </a>
        ))}
      </div>

    </div>
  </section>

  <!-- ═══════════════════ MANIFESTO (pequeno) ═══════════════════ -->
  <section class="manifesto">
    <div class="manifesto-inner">
      <p class="manifesto-text font-garamond">
        Qamareth é um universo de fantasia arcano-musical criado para ser
        jogado, expandido e compartilhado. Todo conteúdo publicado aqui é
        oficial e compatível com o sistema proprietário de regras.
        Derivações e adaptações são bem-vindas sob os termos da licença.
      </p>
    </div>
  </section>

</Layout>

<style>
  /* ═══ HERO ═══ */
  .hero {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    padding: 72px 24px 64px;
    gap: 0;
  }

  .hero-sigil {
    animation: qa-fade-in 1s var(--ease-out) both;
    filter: drop-shadow(0 0 32px rgba(201, 164, 75, 0.18));
    margin-bottom: 32px;
  }
  .hero-sigil:hover {
    filter: drop-shadow(0 0 48px rgba(201, 164, 75, 0.35));
    transition: filter 0.6s;
  }

  .hero-title {
    font-size: clamp(2.8rem, 7vw, 5rem);
    font-weight: 400;
    letter-spacing: 0.18em;
    color: var(--gold-bright);
    text-shadow: 0 0 60px rgba(228, 196, 122, 0.22);
    animation: qa-rise 0.9s var(--ease-out) 0.15s both;
    margin-bottom: 20px;
  }

  .hero-ornament {
    display: flex;
    align-items: center;
    gap: 14px;
    width: 260px;
    animation: qa-fade-in 0.8s var(--ease-out) 0.3s both;
    margin-bottom: 20px;
  }
  .orn-line {
    flex: 1;
    height: 1px;
    background: linear-gradient(to right, transparent, var(--gold-dim));
  }
  .orn-line:last-child {
    background: linear-gradient(to left, transparent, var(--gold-dim));
  }
  .orn-gem {
    color: var(--gold);
    font-size: 0.7rem;
    animation: pulse-glow 4s ease-in-out infinite;
  }

  .hero-tagline {
    font-size: clamp(1.05rem, 2.2vw, 1.22rem);
    font-style: italic;
    color: var(--text-muted);
    line-height: 1.85;
    max-width: 540px;
    animation: qa-rise 0.9s var(--ease-out) 0.4s both;
    margin-bottom: 20px;
  }
  .hero-tagline em {
    color: var(--gold);
    font-style: italic;
    font-weight: 500;
  }

  .hero-system {
    font-size: 0.68rem;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: var(--text-faint);
    animation: qa-fade-in 0.8s var(--ease-out) 0.6s both;
  }

  /* ═══ CARDS ═══ */
  .cards-section {
    padding: 0 24px 0;
    animation: qa-drift 0.8s var(--ease-out) 0.5s both;
  }

  .cards-wrap {
    max-width: 1000px;
    margin: 0 auto;
  }

  .section-divider {
    display: flex;
    align-items: center;
    gap: 20px;
    margin-bottom: 36px;
  }
  .div-line {
    flex: 1;
    height: 1px;
    background: var(--border);
  }
  .div-center {
    font-size: 0.65rem;
    letter-spacing: 0.35em;
    text-transform: uppercase;
    color: var(--text-faint);
  }

  .cards-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 16px;
  }

  .card {
    position: relative;
    display: grid;
    grid-template-columns: auto 1fr auto;
    align-items: start;
    gap: 16px;
    padding: 24px 22px;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    text-decoration: none;
    transition:
      transform     0.2s var(--ease-out),
      border-color  0.2s,
      background    0.2s,
      box-shadow    0.3s;
    animation: qa-drift 0.7s var(--ease-out) both;
    overflow: hidden;
  }

  /* Brilho de canto */
  .card::before {
    content: '';
    position: absolute;
    top: -1px; left: -1px; right: -1px;
    height: 1px;
    background: linear-gradient(to right, transparent, var(--gold-ghost), transparent);
    border-radius: var(--radius-lg) var(--radius-lg) 0 0;
    opacity: 0;
    transition: opacity 0.3s;
  }
  .card:hover::before { opacity: 1; }

  .card:hover {
    transform: translateY(-3px);
    border-color: var(--gold-hover);
    background: var(--surface-2);
    box-shadow: 0 12px 40px rgba(0, 0, 0, 0.5), 0 0 0 1px var(--gold-ghost);
  }

  .card-glyph {
    font-size: 1.7rem;
    color: var(--gold-dim);
    line-height: 1;
    margin-top: 2px;
    transition: color 0.2s, text-shadow 0.2s;
    width: 36px;
    text-align: center;
  }
  .card:hover .card-glyph {
    color: var(--gold);
    text-shadow: 0 0 16px rgba(201,164,75,0.5);
  }

  .card-body { min-width: 0; }

  .card-title {
    font-size: 0.78rem;
    font-weight: 600;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--gold);
    margin-bottom: 8px;
    transition: color 0.2s;
  }
  .card:hover .card-title { color: var(--gold-bright); }

  .card-desc {
    font-size: 0.97rem;
    line-height: 1.65;
    color: var(--text-muted);
    transition: color 0.2s;
  }
  .card:hover .card-desc { color: var(--text); }

  .card-arrow {
    font-size: 1rem;
    color: var(--text-faint);
    margin-top: 3px;
    transition: transform 0.2s var(--ease-out), color 0.2s;
    flex-shrink: 0;
  }
  .card:hover .card-arrow {
    transform: translateX(4px);
    color: var(--gold-dim);
  }

  /* Variantes de borda por seção (sutil) */
  .card--lore:hover  { border-color: rgba(158, 175, 191, 0.28); }
  .card--grim:hover  { border-color: rgba(201, 164, 75, 0.38); box-shadow: 0 12px 40px rgba(0,0,0,0.5), 0 0 24px rgba(201,164,75,0.06); }

  /* ═══ MANIFESTO ═══ */
  .manifesto {
    padding: 60px 24px 0;
  }
  .manifesto-inner {
    max-width: 640px;
    margin: 0 auto;
    text-align: center;
    border-top: 1px solid var(--border-2);
    padding-top: 48px;
  }
  .manifesto-text {
    font-size: 0.98rem;
    font-style: italic;
    color: var(--text-faint);
    line-height: 1.9;
  }

  /* ═══ RESPONSIVO ═══ */
  @media (max-width: 720px) {
    .hero { padding: 52px 20px 48px; }
    .hero-sigil :global(svg) { width: 220px !important; height: 220px !important; }

    .cards-grid {
      grid-template-columns: 1fr;
    }

    .card {
      grid-template-columns: auto 1fr;
    }
    .card-arrow { display: none; }
  }

  @media (max-width: 480px) {
    .hero-ornament { width: 200px; }
  }
</style>
