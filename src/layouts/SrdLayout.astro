function normalize(s: string): string {
  return s.toLowerCase().normalize('NFD').replace(/[\u0300-\u036f]/g, '').replace(/[^a-z0-9\s]/g, ' ');
}

function score(entry: SearchEntry, query: string): number {
  const q = normalize(query);
  const words = q.split(/\s+/).filter(Boolean);
  let pts = 0;
  const title = normalize(entry.title);
  words.forEach(w => {
    if (title.includes(w)) pts += 10;
    entry.keywords.forEach(k => { if (k.includes(w) || w.includes(k)) pts += 3; });
  });
  return pts;
}

function render(results: SearchEntry[], query: string) {
  const box = document.getElementById('srd-search-results') as HTMLElement;
  if (!results.length) {
    box.innerHTML = `<p class="srd-no-results">Nenhum resultado para <em>"${query}"</em></p>`;
  } else {
    box.innerHTML = results.slice(0, 7).map(r =>
      `<a href="${r.href}" class="srd-result-link font-garamond">${r.title}</a>`
    ).join('');
  }
  box.hidden = false;
}

function initSearch() {
  const input = document.getElementById('srd-search-input') as HTMLInputElement;
  const box = document.getElementById('srd-search-results') as HTMLElement;
  if (!input || !box) return;

  let timer: ReturnType<typeof setTimeout>;

  input.addEventListener('input', () => {
    clearTimeout(timer);
    const q = input.value.trim();
    if (q.length < 2) { box.hidden = true; return; }
    timer = setTimeout(() => {
      const scored = INDEX
        .map(e => ({ entry: e, pts: score(e, q) }))
        .filter(x => x.pts > 0)
        .sort((a, b) => b.pts - a.pts);
      if (scored.length) render(scored.map(x => x.entry), q);
      else render([], q);
    }, 180);
  });

  // Fechar ao clicar fora
  document.addEventListener('click', (e) => {
    if (!input.contains(e.target as Node) && !box.contains(e.target as Node)) {
      box.hidden = true;
    }
  });

  // Reabrir ao focar
  input.addEventListener('focus', () => {
    if (input.value.trim().length >= 2) box.hidden = false;
  });
}

document.addEventListener('DOMContentLoaded', initSearch);
document.addEventListener('astro:page-load', initSearch);
</script>

