---
import '../styles/global.css';

interface Props {
  title?: string;
  frontmatter?: { title?: string };
}

// Suporte a frontmatter de .md e props diretas de .astro
const { title: propTitle, frontmatter } = Astro.props;
const title = frontmatter?.title ?? propTitle ?? 'SRD';
const fullTitle = `${title} · SRD · Qamareth`;

const currentPath = Astro.url.pathname;

const chapters = [
  { href: '/srd',                          label: 'Visão Geral',             num: ''   },
  { href: '/srd/00-introducao',            label: 'Introdução',              num: '00' },
  { href: '/srd/01-criacao-personagem',    label: 'Criação de Personagem',   num: '01' },
  { href: '/srd/02-atributos',             label: 'Atributos e Disciplinas', num: '02' },
  { href: '/srd/03-testes',                label: 'Testes e Rolagens',       num: '03' },
  { href: '/srd/04-magia-musical',         label: 'Magia Musical',           num: '04' },
  { href: '/srd/05-tensao-harmonica',      label: 'Tensão Harmônica',        num: '05' },
  { href: '/srd/06-combate',               label: 'Combate',                 num: '06' },
  { href: '/srd/07-ferimentos',            label: 'Ferimentos',              num: '07' },
  { href: '/srd/08-magi-tech',             label: 'Magi-Tech',               num: '08' },
  { href: '/srd/09-honra-status-influencia', label: 'Honra, Status, Influência', num: '09' },
  { href: '/srd/10-paixoes',               label: 'Paixões',                 num: '10' },
  { href: '/srd/11-bestiario-arquetipos',  label: 'Arquétipos de Inimigos',  num: '11' },
  { href: '/srd/12-temas-e-conflitos',     label: 'Temas e Conflitos',       num: '12' },
  { href: '/srd/13-faccoes',               label: 'Facções',                 num: '13' },
  { href: '/srd/14-economia',              label: 'Economia',                num: '14' },
  { href: '/srd/15-bastions',              label: 'Bastions',                num: '15' },
  { href: '/srd/16-influencia-politica',   label: 'Influência Política',     num: '16' },
  { href: '/srd/17-magia-coletiva',        label: 'Magia Coletiva',          num: '17' },
  { href: '/srd/18-ritmo-tempo-combate',   label: 'Ritmo e Tempo',           num: '18' },
  { href: '/srd/19-motivos-combate',       label: 'Motivos de Combate',      num: '19' },
  { href: '/srd/20-escolas-e-tradicoes',   label: 'Escolas e Tradições',     num: '20' },
  { href: null,                            label: '— Templates —',           num: '',  separator: true },
  { href: '/templates',                    label: 'Índice de Templates',     num: ''   },
  { href: '/templates/partitura',          label: 'Template · Partitura',    num: '90' },
  { href: '/templates/inimigo',            label: 'Template · Inimigo',      num: '91' },
  { href: '/templates/escola',             label: 'Template · Escola',       num: '92' },
  { href: '/templates/grimorio',           label: 'Template · Grimório',     num: '◈'  },
];

// Acha o índice atual para navegação prev/next
const currentIndex = chapters.findIndex(c => c.href === currentPath);
const prev = currentIndex > 0 ? chapters[currentIndex - 1] : null;
const next = currentIndex >= 0 && currentIndex < chapters.length - 1 ? chapters[currentIndex + 1] : null;
---

<!doctype html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
  <meta name="generator" content={Astro.generator} />
  <title>{fullTitle}</title>
</head>
<body>

  <!-- ═══ NAV GLOBAL ═══ -->
  <header class="site-nav">
    <nav class="nav-inner">
      <a href="/" class="nav-logo" aria-label="Qamareth — início">
        <svg viewBox="0 0 32 32" width="28" height="28" aria-hidden="true">
          <circle cx="16" cy="16" r="13.5" fill="none" stroke="#c9a44b" stroke-width="0.9" opacity="0.5"/>
          <circle cx="16" cy="16" r="7" fill="none" stroke="#c9a44b" stroke-width="1.2"
            style="clip-path: url(#nav-c);" opacity="0.9"/>
          <defs>
            <clipPath id="nav-c">
              <path d="M32,0 L32,32 L0,32 L0,0 Z M22,15.5 m-6.5,0 a6.5,6.5 0 1,0 13,0 a6.5,6.5 0 1,0 -13,0" fill-rule="evenodd"/>
            </clipPath>
          </defs>
          <g stroke="#c9a44b" stroke-width="0.7" opacity="0.6">
            <line x1="6" y1="14.5" x2="26" y2="14.5"/>
            <line x1="6" y1="16"   x2="26" y2="16"/>
            <line x1="6" y1="17.5" x2="26" y2="17.5"/>
          </g>
          <circle cx="16" cy="16" r="1.5" fill="#e4c47a" opacity="0.95"/>
        </svg>
        <span class="nav-logo-text font-cinzel-d">Qamareth</span>
      </a>
      <ul class="nav-links" role="list">
        {[
          { href: '/srd',       label: 'SRD'       },
          { href: '/lore',      label: 'Lore'      },
          { href: '/grimorios', label: 'Grimórios' },
          { href: '/templates', label: 'Templates' },
        ].map(link => (
          <li>
            <a
              href={link.href}
              class:list={['nav-link font-cinzel', currentPath.startsWith(link.href) && 'nav-link--active']}
            >
              {link.label}
            </a>
          </li>
        ))}
      </ul>
    </nav>
    <div class="nav-line" aria-hidden="true">
      <div class="nav-line-diamond"></div>
    </div>
  </header>

  <!-- ═══ SHELL ═══ -->
  <div class="srd-shell">

    <!-- SIDEBAR -->
    <aside class="srd-sidebar" id="srd-sidebar">
      <div class="sidebar-header font-cinzel">
        <a href="/" class="sidebar-home-link" aria-label="Voltar ao início">
          <span class="sidebar-home-glyph" aria-hidden="true">←</span>
          Início
        </a>
        <span class="sidebar-header-label">SRD</span>
      </div>

      <!-- ── BUSCA ── -->
      <div class="srd-search-wrap">
        <input
          type="search"
          id="srd-search-input"
          class="srd-search font-garamond"
          placeholder="Buscar no SRD…"
          autocomplete="off"
          spellcheck="false"
        />
        <span class="srd-search-icon" aria-hidden="true">⌕</span>
      </div>
      <div id="srd-search-results" class="srd-search-results" hidden></div>
      <!-- ── FIM BUSCA ── -->

      <nav class="sidebar-nav" aria-label="Capítulos do SRD">
        {chapters.map(ch => (
          ch.separator
            ? <span class="chapter-separator font-cinzel">{ch.label}</span>
            : <a
                href={ch.href}
                class:list={['chapter-link font-garamond', currentPath === ch.href && 'chapter-link--active']}
              >
                {ch.num && <span class="chapter-num">{ch.num}</span>}
                <span class="chapter-label">{ch.label}</span>
              </a>
        ))}
      </nav>
    </aside>

    <!-- CONTEÚDO -->
    <div class="srd-content">

      <!-- Breadcrumb -->
      <nav class="breadcrumb font-cinzel" aria-label="Localização">
        <a href="/" class="breadcrumb-link">Início</a>
        <span class="breadcrumb-sep" aria-hidden="true">›</span>
        <a href="/srd" class="breadcrumb-link">SRD</a>
        <span class="breadcrumb-sep" aria-hidden="true">›</span>
        <span class="breadcrumb-current">{title}</span>
      </nav>

      <!-- Prose -->
      <article class="prose">
        <slot />
      </article>

      <!-- Navegação prev/next -->
      {(prev || next) && (
        <nav class="chapter-nav" aria-label="Capítulos adjacentes">
          <div class="chapter-nav-inner">
            {prev
              ? (
                <a href={prev.href} class="chapter-nav-link chapter-nav-link--prev font-cinzel">
                  <span class="chapter-nav-arrow" aria-hidden="true">←</span>
                  <span class="chapter-nav-text">
                    <span class="chapter-nav-label">Anterior</span>
                    <span class="chapter-nav-title">{prev.label}</span>
                  </span>
                </a>
              )
              : <div></div>
            }
            {next && (
              <a href={next.href} class="chapter-nav-link chapter-nav-link--next font-cinzel">
                <span class="chapter-nav-text">
                  <span class="chapter-nav-label">Próximo</span>
                  <span class="chapter-nav-title">{next.label}</span>
                </span>
                <span class="chapter-nav-arrow" aria-hidden="true">→</span>
              </a>
            )}
          </div>
        </nav>
      )}

    </div>
  </div>

  <!-- ═══ FOOTER ═══ -->
  <footer class="site-footer">
    <div class="footer-inner">
      <div class="footer-text font-garamond">
        Qamareth SRD
        <span class="footer-sep">·</span>
        <a href="https://creativecommons.org/licenses/by/4.0/" target="_blank" rel="noopener" class="footer-license">
          CC BY 4.0
        </a>
        <span class="footer-sep">·</span>
        <a href="https://oliceu.com" target="_blank" rel="noopener" class="footer-home">oliceu.com</a>
      </div>
    </div>
  </footer>

</body>
</html>

<style>
  /* ─── NAV ─── */
  .site-nav {
    position: sticky; top: 0; z-index: 100;
    background: rgba(6,7,13,0.9);
    backdrop-filter: blur(18px);
    -webkit-backdrop-filter: blur(18px);
  }
  .nav-inner {
    max-width: 1280px; margin: 0 auto; padding: 0 24px;
    height: 58px; display: flex; align-items: center; gap: 20px;
  }
  .nav-logo { display: flex; align-items: center; gap: 9px; text-decoration: none; flex-shrink: 0; }
  .nav-logo-text {
    font-size: 1rem; letter-spacing: 0.08em; color: var(--gold-bright);
    transition: color 0.2s;
  }
  .nav-logo:hover .nav-logo-text { color: #fff; }
  .nav-links { display: flex; align-items: center; gap: 4px; list-style: none; margin-left: auto; }
  .nav-link {
    padding: 5px 12px; font-size: 0.68rem; letter-spacing: 0.18em;
    text-transform: uppercase; color: var(--text-muted);
    border: 1px solid transparent; border-radius: var(--radius-sm);
    transition: color 0.2s, border-color 0.2s, background 0.2s;
  }
  .nav-link:hover, .nav-link--active {
    color: var(--gold); border-color: var(--border); background: var(--gold-ghost);
  }
  .nav-link--active { color: var(--gold-bright); }
  .nav-line {
    height: 1px;
    background: linear-gradient(to right, transparent, var(--gold-border) 20%, var(--gold-border) 80%, transparent);
    display: flex; align-items: center; justify-content: center; position: relative;
  }
  .nav-line-diamond {
    width: 5px; height: 5px; background: var(--gold-dim);
    transform: rotate(45deg); position: absolute;
  }

  /* ─── SHELL ─── */
  .srd-shell {
    max-width: 1280px; margin: 0 auto;
    display: grid;
    grid-template-columns: 240px 1fr;
    gap: 0;
    min-height: calc(100vh - 59px - 72px);
  }

  /* ─── SIDEBAR ─── */
  .srd-sidebar {
    position: sticky; top: 59px;
    height: calc(100vh - 59px);
    overflow-y: auto;
    border-right: 1px solid var(--border-2);
    padding: 28px 0 40px;
    scrollbar-width: thin;
    scrollbar-color: var(--gold-border) transparent;
    flex-shrink: 0;
  }

  .sidebar-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0 20px 12px;
    border-bottom: 1px solid var(--border);
    margin-bottom: 8px;
  }

  .sidebar-home-link {
    display: flex;
    align-items: center;
    gap: 5px;
    font-size: 0.58rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--text-faint);
    text-decoration: none;
    transition: color 0.2s;
  }
  .sidebar-home-link:hover { color: var(--gold-dim); }
  .sidebar-home-glyph {
    font-size: 0.72rem;
    transition: transform 0.2s;
  }
  .sidebar-home-link:hover .sidebar-home-glyph { transform: translateX(-3px); }

  .sidebar-header-label {
    font-size: 0.58rem;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: var(--gold-dim);
  }

  .sidebar-nav { display: flex; flex-direction: column; }

  .chapter-link {
    display: flex; align-items: baseline; gap: 10px;
    padding: 7px 20px;
    font-size: 0.9rem;
    color: var(--text-faint);
    text-decoration: none;
    border-right: 2px solid transparent;
    transition: color 0.15s, background 0.15s, border-color 0.15s;
    line-height: 1.4;
  }
  .chapter-link:hover {
    color: var(--text-muted);
    background: var(--gold-ghost);
    border-right-color: var(--gold-dim);
  }
  .chapter-link--active {
    color: var(--gold);
    background: var(--gold-ghost);
    border-right-color: var(--gold);
  }
  .chapter-num {
    font-family: 'Cinzel', serif;
    font-size: 0.6rem; letter-spacing: 0.1em;
    color: var(--text-faint);
    flex-shrink: 0;
    min-width: 20px;
    transition: color 0.15s;
  }
  .chapter-link--active .chapter-num,
  .chapter-link:hover .chapter-num { color: var(--gold-dim); }
  .chapter-label { line-height: 1.3; }
  .chapter-separator {
    display: block; padding: 16px 12px 4px;
    font-size: 0.52rem; letter-spacing: 0.25em; text-transform: uppercase;
    color: var(--text-faint); pointer-events: none; user-select: none;
  }

  /* ─── CONTENT ─── */
  .srd-content {
    padding: 32px 48px 72px;
    min-width: 0;
  }

  /* ─── BREADCRUMB ─── */
  .breadcrumb {
    display: flex; align-items: center; gap: 6px;
    font-size: 0.6rem; letter-spacing: 0.15em; text-transform: uppercase;
    color: var(--text-faint); margin-bottom: 28px;
  }
  .breadcrumb-link { color: var(--text-faint); transition: color 0.2s; }
  .breadcrumb-link:hover { color: var(--gold-dim); }
  .breadcrumb-sep { opacity: 0.4; }
  .breadcrumb-current { color: var(--gold-dim); }

  /* ─── PROSE ─── */
  .prose { max-width: 720px; }

  .prose :global(h1) {
    font-family: 'Cinzel Decorative', serif;
    font-size: clamp(1.5rem, 3vw, 2.2rem);
    font-weight: 400; color: var(--gold-bright);
    letter-spacing: 0.06em;
    margin: 0 0 10px; line-height: 1.2;
  }
  .prose :global(h2) {
    font-family: 'Cinzel', serif;
    font-size: 1rem; font-weight: 600;
    color: var(--gold); letter-spacing: 0.14em; text-transform: uppercase;
    margin: 44px 0 14px; padding-bottom: 8px;
    border-bottom: 1px solid var(--border);
  }
  .prose :global(h3) {
    font-family: 'Cinzel', serif;
    font-size: 0.82rem; font-weight: 600;
    color: var(--text); letter-spacing: 0.1em; text-transform: uppercase;
    margin: 28px 0 10px;
  }
  .prose :global(h4) {
    font-family: 'EB Garamond', serif;
    font-size: 1.05rem; font-style: italic; font-weight: 500;
    color: var(--text-muted); margin: 20px 0 6px;
  }
  .prose :global(p) {
    font-size: 1.05rem; line-height: 1.85;
    color: var(--text-muted); margin: 0 0 14px;
  }
  .prose :global(strong) { color: var(--text); font-weight: 600; }
  .prose :global(em) { color: var(--gold-dim); font-style: italic; }
  .prose :global(ul), .prose :global(ol) {
    margin: 0 0 16px; padding-left: 20px;
    color: var(--text-muted); line-height: 1.8;
  }
  .prose :global(li) { margin-bottom: 5px; }
  .prose :global(li::marker) { color: var(--gold-dim); }
  .prose :global(blockquote) {
    border-left: 3px solid var(--gold-dim);
    background: var(--surface);
    padding: 14px 18px;
    margin: 20px 0;
    border-radius: 0 var(--radius-sm) var(--radius-sm) 0;
    font-style: italic;
    color: var(--text-muted);
  }
  .prose :global(blockquote p) { margin: 0; }
  .prose :global(hr) {
    border: none;
    border-top: 1px solid var(--border);
    margin: 36px 0;
    position: relative;
  }
  .prose :global(table) {
    width: 100%; border-collapse: collapse; margin: 20px 0; font-size: 0.95rem;
  }
  .prose :global(th) {
    font-family: 'Cinzel', serif; font-size: 0.62rem;
    letter-spacing: 0.15em; text-transform: uppercase;
    color: var(--gold); text-align: left;
    padding: 9px 12px; border-bottom: 1px solid var(--border);
  }
  .prose :global(td) {
    padding: 9px 12px; color: var(--text-muted);
    border-bottom: 1px solid var(--border-2); vertical-align: top;
  }
  .prose :global(tr:hover td) { background: var(--gold-ghost); }
  .prose :global(code) {
    font-family: monospace;
    font-size: 0.88em;
    background: var(--surface-2);
    border: 1px solid var(--border);
    border-radius: 4px;
    padding: 1px 6px;
    color: var(--gold-dim);
  }

  /* Links de navegação footer (.md usa esses) */
  .prose :global(a) {
    color: var(--gold-dim);
    text-decoration: none;
    border-bottom: 1px solid var(--gold-border);
    transition: color 0.2s, border-color 0.2s;
  }
  .prose :global(a:hover) {
    color: var(--gold);
    border-bottom-color: var(--gold-dim);
  }

  /* ─── PREV/NEXT ─── */
  .chapter-nav { margin-top: 64px; padding-top: 28px; border-top: 1px solid var(--border); max-width: 720px; }
  .chapter-nav-inner { display: flex; justify-content: space-between; gap: 16px; }

  .chapter-nav-link {
    display: flex; align-items: center; gap: 12px;
    padding: 14px 18px;
    background: var(--surface); border: 1px solid var(--border);
    border-radius: var(--radius); text-decoration: none;
    transition: border-color 0.2s, background 0.2s, transform 0.15s;
    max-width: 48%;
    flex: 1;
  }
  .chapter-nav-link--next { justify-content: flex-end; text-align: right; }
  .chapter-nav-link:hover {
    border-color: var(--gold-hover); background: var(--surface-2);
    transform: translateY(-1px);
  }
  .chapter-nav-arrow { font-size: 1.1rem; color: var(--gold-dim); flex-shrink: 0; }
  .chapter-nav-text { display: flex; flex-direction: column; gap: 2px; }
  .chapter-nav-label {
    font-size: 0.6rem; letter-spacing: 0.2em; text-transform: uppercase; color: var(--text-faint);
  }
  .chapter-nav-title { font-size: 0.85rem; color: var(--gold); }

  /* ─── FOOTER ─── */
  .site-footer { border-top: 1px solid var(--border-2); padding: 20px 24px; }
  .footer-inner { max-width: 1280px; margin: 0 auto; }
  .footer-text { font-size: 0.85rem; color: var(--text-faint); display: flex; gap: 8px; flex-wrap: wrap; }
  .footer-sep { opacity: 0.4; }
  .footer-license, .footer-home { color: var(--text-faint); transition: color 0.2s; }
  .footer-license:hover, .footer-home:hover { color: var(--gold-dim); }

  /* ─── RESPONSIVO ─── */
  @media (max-width: 900px) {
    .srd-shell { grid-template-columns: 1fr; }
    .srd-sidebar {
      position: static; height: auto; overflow: visible;
      border-right: none; border-bottom: 1px solid var(--border);
      padding: 16px 0;
    }
    .sidebar-nav { flex-direction: row; flex-wrap: wrap; padding: 0 16px; gap: 4px; }
    .chapter-link {
      padding: 5px 10px; font-size: 0.82rem;
      border-right: none; border: 1px solid transparent;
      border-radius: var(--radius-sm);
    }
    .chapter-link--active, .chapter-link:hover { border-color: var(--border); }
    .chapter-num { display: none; }
    .srd-content { padding: 24px 20px 48px; }
    .chapter-nav-inner { flex-direction: column; }
    .chapter-nav-link { max-width: 100%; }
  }
</style>

<script>
// ── SRD Search ────────────────────────────────────────────────────────────────
// Índice construído a partir dos títulos dos capítulos + conteúdo estático.
// Busca client-side sem dependências externas.

interface SearchEntry {
  href: string;
  title: string;
  keywords: string[];
}

const INDEX: SearchEntry[] = [
  { href: '/srd/00-introducao',           title: 'Introdução',                  keywords: ['introducao','sistema','qamareth','musical','ressonancia'] },
  { href: '/srd/01-criacao-personagem',   title: 'Criação de Personagem',        keywords: ['criacao','personagem','origem','motivo','background','ficha'] },
  { href: '/srd/02-atributos',            title: 'Atributos e Disciplinas',      keywords: ['atributo','disciplina','pilar','forca','vigor','destreza','presenca','intelecto','vontade'] },
  { href: '/srd/03-testes',               title: 'Testes e Rolagens',            keywords: ['teste','rolagem','dado','dificuldade','sucesso','falha','explosao'] },
  { href: '/srd/04-magia-musical',        title: 'Magia Musical',                keywords: ['magia','musical','modo','ritmo','intervalo','jonico','dorico','frigio','lidio','mixolidio','eolio','locrio'] },
  { href: '/srd/05-tensao-harmonica',     title: 'Tensão Harmônica',             keywords: ['tensao','harmonica','peso','ruptura','dissonancia','nivel'] },
  { href: '/srd/06-combate',              title: 'Combate',                      keywords: ['combate','postura','forte','legato','staccato','rubato','tempo','cena','turno','iniciativa'] },
  { href: '/srd/07-ferimentos',           title: 'Ferimentos',                   keywords: ['ferimento','trilha','ileso','arranhado','ferido','gravemente','mortal','morte','cura'] },
  { href: '/srd/08-magi-tech',            title: 'Magi-Tech',                    keywords: ['magi','tech','tecnologia','arcana','dispositivo','cristal','mecanismo'] },
  { href: '/srd/09-honra-status-influencia', title: 'Honra, Status, Influência', keywords: ['honra','status','influencia','reputacao','faccao','alianca'] },
  { href: '/srd/10-paixoes',              title: 'Paixões',                      keywords: ['paixao','motivacao','trauma','virtude','vicio','impulso'] },
  { href: '/srd/11-bestiario-arquetipos', title: 'Arquétipos de Inimigos',       keywords: ['inimigo','bestiario','arquetipo','antagonista','criatura','npc'] },
  { href: '/srd/12-temas-e-conflitos',    title: 'Temas e Conflitos',            keywords: ['tema','conflito','narrativa','drama','arco'] },
