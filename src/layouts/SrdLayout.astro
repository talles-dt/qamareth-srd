---
const { title } = Astro.props;

const chapters = [
  ["00-introducao", "Introdução"],
  ["01-criacao-personagem", "Criação de Personagem"],
  ["02-atributos", "Atributos e Disciplinas"],
  ["03-testes", "Resolução de Testes"],
  ["04-magia-musical", "Magia Musical"],
  ["05-tensao-harmonica", "Tensão Harmônica"],
  ["06-combate", "Combate"],
  ["07-ferimentos", "Ferimentos"],
  ["08-magi-tech", "Magi-Tech"],
  ["09-honra-status-influencia", "Honra, Status e Influência"],
  ["10-paixoes", "Paixões"],
  ["11-bestiario-arquetipos", "Arquétipos de Inimigos"],
  ["12-temas-e-conflitos", "Temas e Conflitos"],
  ["13-faccoes", "Facções e Poder"],
  ["14-economia", "Economia e Recursos"],
  ["15-bastions", "Bastions"],
  ["16-influencia-politica", "Influência e Política"],
  ["17-magia-coletiva", "Magia Coletiva e Corais"],
  ["18-ritmo-tempo-combate", "Ritmo e Tempo de Combate"],
  ["19-motivos-combate", "Motivos de Combate"],
  ["20-escolas-e-tradicoes", "Escolas e Tradições"],
  ["99-licenca", "Licença"]
];

const currentPath = Astro.url.pathname;
---

<html lang="pt-BR">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title ? `${title} • Qamareth SRD` : "Qamareth SRD"}</title>
    <style>
      :root {
        --bg: #0b0c10;
        --panel: #11141b;
        --panel-2: #0f1117;
        --text: #e9e2d0;
        --muted: #b8b0a0;
        --accent: #c9a44b;
        --border: rgba(233,226,208,.12);
      }

      * { box-sizing: border-box; }

      body {
        margin: 0;
        font-family: system-ui, sans-serif;
        background: var(--bg);
        color: var(--text);
      }

      a {
        color: var(--accent);
        text-decoration: none;
      }

      a:hover {
        text-decoration: underline;
      }

      .shell {
        display: grid;
        grid-template-columns: 280px 1fr;
        min-height: 100vh;
      }

      .sidebar {
        background: var(--panel);
        border-right: 1px solid var(--border);
        padding: 24px 18px;
        position: sticky;
        top: 0;
        height: 100vh;
        overflow-y: auto;
      }

      .sidebar h1 {
        font-size: 1.1rem;
        margin: 0 0 8px 0;
      }

      .sidebar p {
        color: var(--muted);
        margin: 0 0 18px 0;
        font-size: .95rem;
      }

      .sidebar nav ul {
        list-style: none;
        padding: 0;
        margin: 0;
      }

      .sidebar nav li {
        margin: 0 0 8px 0;
      }

      .sidebar nav a {
        display: block;
        padding: 8px 10px;
        border-radius: 10px;
        color: var(--text);
      }

      .sidebar nav a.active {
        background: rgba(201,164,75,.12);
        border: 1px solid rgba(201,164,75,.25);
        color: var(--accent);
      }

      .content {
        padding: 32px 24px;
      }

      .article {
        max-width: 860px;
        margin: 0 auto;
        background: var(--panel-2);
        border: 1px solid var(--border);
        border-radius: 18px;
        padding: 28px;
      }

      .article h1:first-child {
        margin-top: 0;
      }

      .article p,
      .article li {
        line-height: 1.75;
      }

      .toplinks {
        margin-bottom: 18px;
        color: var(--muted);
        font-size: .95rem;
      }

      @media (max-width: 900px) {
        .shell {
          grid-template-columns: 1fr;
        }

        .sidebar {
          position: relative;
          height: auto;
          border-right: none;
          border-bottom: 1px solid var(--border);
        }

        .content {
          padding: 18px;
        }

        .article {
          padding: 20px;
        }
      }
    </style>
  </head>
  <body>
    <div class="shell">
      <aside class="sidebar">
        <h1>Qamareth SRD</h1>
        <p>Magia musical, intriga, bastions e magi-tech.</p>

        <nav>
          <ul>
            <li><a href="/srd">Índice</a></li>
            {chapters.map(([slug, label]) => {
              const href = `/srd/${slug}`;
              const active = currentPath === href;
              return (
                <li>
                  <a href={href} class={active ? "active" : ""}>
                    {label}
                  </a>
                </li>
              );
            })}
          </ul>
        </nav>
      </aside>

      <main class="content">
        <div class="article">
          <div class="toplinks">
            <a href="/">Início</a> · <a href="/srd">Índice do SRD</a>
          </div>
          <slot />
        </div>
      </main>
    </div>
  </body>
</html>
