---
interface Props {
  title?: string;
  section?: string;
}

const { title, section } = Astro.props;
const sectionName = section ? section.toUpperCase() : "SEÇÃO";
---
<html lang="pt-BR">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title ? `${title} • Qamareth` : "Qamareth"}</title>
    <style>
      :root {
        color-scheme: dark;
      }
      body {
        margin: 0;
        font-family: system-ui, -apple-system, sans-serif;
        background: #0b0c10;
        color: #e9e2d0;
      }
      main {
        max-width: 980px;
        margin: 0 auto;
        padding: 32px 18px 60px;
      }
      article {
        background: #0f1117;
        border: 1px solid rgba(233, 226, 208, 0.15);
        border-radius: 16px;
        padding: 24px;
        line-height: 1.7;
      }
      a {
        color: #c9a44b;
      }
      h1, h2, h3 {
        line-height: 1.3;
      }
      .badge {
        display: inline-block;
        margin-bottom: 12px;
        padding: 4px 10px;
        border-radius: 999px;
        border: 1px solid rgba(201, 164, 75, 0.45);
        color: #c9a44b;
        font-size: 0.8rem;
        letter-spacing: 0.06em;
      }
    </style>
  </head>
  <body>
    <main>
      <article>
        <p class="badge">{sectionName}</p>
        <slot />
      </article>
    </main>
  </body>
</html>
